{
  "name": "admin-study-catalyst",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently --names be,fe --prefix-colors cyan,magenta \"yarn dev:be\" \"yarn dev:fe\"",
    "dev:be": "yarn workspace @admin-study-catalyst/backend dev",
    "dev:fe": "yarn workspace @admin-study-catalyst/frontend dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "packageManager": "yarn@4.14.1"
}
